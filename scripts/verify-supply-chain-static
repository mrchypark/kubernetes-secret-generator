#!/bin/sh
# shellcheck disable=SC2016 # Policy checks intentionally match literal workflow variables.
set -eu

root=${1:-.}
workflows=$root/.github/workflows
fail() { printf 'supply-chain policy: %s\n' "$*" >&2; exit 1; }
has() { grep -F -q -- "$2" "$1" || fail "$(basename "$1") is missing: $2"; }
count() { [ "$(grep -E -c -- "$2" "$1" || true)" -eq "$3" ] || fail "$(basename "$1") must contain $3 matches for: $2"; }

command -v actionlint >/dev/null 2>&1 || fail 'actionlint is required'
actionlint "$workflows"/*.yml

workflow_names=$(find "$workflows" -maxdepth 1 -type f \( -name '*.yml' -o -name '*.yaml' \) -exec basename {} \; | sort | tr '\n' ' ')
[ "$workflow_names" = 'ci.yml release-candidate.yml release-promote.yml ' ] || fail 'workflow names must be exactly ci, release-candidate, and release-promote'

ci=$workflows/ci.yml
candidate=$workflows/release-candidate.yml
promote=$workflows/release-promote.yml
[ "$(awk '$0=="jobs:"{jobs=1;next} jobs&&/^  [[:alnum:]_-]+:$/{print $1}' "$ci")" = ci: ] || fail 'ci.yml must contain exactly the ci job'
[ "$(awk '$0=="jobs:"{jobs=1;next} jobs&&/^  [[:alnum:]_-]+:$/{print $1}' "$candidate")" = candidate: ] || fail 'release-candidate.yml must contain exactly the candidate job'
[ "$(awk '$0=="jobs:"{jobs=1;next} jobs&&/^  [[:alnum:]_-]+:$/{print $1}' "$promote")" = promote: ] || fail 'release-promote.yml must contain exactly the promote job'

bad_uses=$(awk '$1=="uses:" {sub(/#.*/, "", $2); if ($2 !~ /@[0-9a-fA-F]{40}$/) print FILENAME ":" NR ":" $2}' "$workflows"/*.yml)
[ -z "$bad_uses" ] || fail "actions must use 40-hex commit pins: $bad_uses"

count "$ci" '^permissions:$' 1
count "$ci" '^  contents: read$' 1
! grep -Eq 'packages:|id-token:|contents: write|write-all' "$ci" || fail 'CI permissions must be read-only'
count "$candidate" '^permissions:$|^    permissions:$' 2
count "$candidate" '^  contents: read$|^      contents: read$' 2
count "$candidate" '^      packages: write$' 1
count "$candidate" '^      id-token: write$' 1
count "$promote" '^permissions:$|^    permissions:$' 2
count "$promote" '^  contents: read$|^      contents: write$' 2
count "$promote" '^      actions: read$' 1
count "$promote" '^      packages: write$' 1

count "$candidate" 'docker/build-push-action@' 1
has "$candidate" 'platforms: linux/amd64,linux/arm64'
has "$candidate" 'candidate-${{ github.run_id }}-${{ github.run_attempt }}'
has "$candidate" 'amd64_digest=$(jq -er'
has "$candidate" 'arm64_digest=$(jq -er'
has "$candidate" 'printf '\''%s\n'\'' "$platform_digest" | grep -Eq '\''^sha256:[0-9a-f]{64}$'\'''
has "$candidate" 'docker run --rm --platform linux/amd64 "$IMAGE_NAME@$amd64_digest"'
has "$candidate" 'docker run --rm --platform linux/arm64 "$IMAGE_NAME@$arm64_digest"'
has "$candidate" 'for arch in amd64 arm64; do'
has "$candidate" 'anchore/grype:'
has "$candidate" 'anchore/syft:'
has "$candidate" 'cosign sign --yes "$IMAGE_NAME@$DIGEST"'
has "$candidate" 'cosign verify --certificate-identity'
count "$candidate" '^[[:space:]]+helm package ' 1
has "$candidate" 'timeout 15m test/e2e/release-smoke.sh >release-smoke-summary.json'
has "$candidate" '.durationSeconds >= 600 and .durationSeconds < 900'
has "$candidate" 'id: scan_failure_diagnostics'
has "$candidate" 'diagnostics_dir="$RUNNER_TEMP/release-candidate-diagnostics"'
has "$candidate" 'rm -rf "$diagnostics_dir"'
has "$candidate" 'mkdir -m 700 "$diagnostics_dir"'
has "$candidate" 'scripts/check-test-artifacts.sh preflight-report.md'
has "$candidate" 'install -m 400 preflight-report.md "$diagnostics_dir/preflight-report.md"'
has "$candidate" 'chmod 500 "$diagnostics_dir"'
has "$candidate" "steps.scan_failure_diagnostics.outcome == 'success'"
has "$candidate" "steps.scan_failure_diagnostics.outputs.ready == 'true'"
has "$candidate" 'path: ${{ steps.scan_failure_diagnostics.outputs.path }}'
! grep -F -q 'path: preflight-report.md' "$candidate" || fail 'failure diagnostics must upload only the scanner-staged copy'
has "$candidate" 'release-smoke-summary.json candidate-artifact/'
tail -8 "$candidate" | grep -q 'actions/upload-artifact@' || fail 'candidate artifact upload must be last'
! grep -Eq 'helm push |imagetools create --tag .*RELEASE_TAG|:latest' "$candidate" || fail 'candidate must not publish immutable or latest targets'

has "$promote" 'workflow_dispatch:'
has "$promote" 'environment: production-release'
has "$promote" 'group: promote-${{ inputs.release_tag }}'
has "$promote" 'cancel-in-progress: false'
has "$promote" 'test "$(grep -Ec '\''^- \[[xX]\] '\'' approval-body.md)" -eq 9'
has "$promote" 'Preflight report run: $run_url'
has "$promote" 'Candidate run: $run_url'
has "$promote" 'Source commit: $SOURCE_COMMIT'
has "$promote" 'docker buildx imagetools create --tag "$IMAGE_NAME:$RELEASE_TAG" "$IMAGE_NAME@$DIGEST"'
has "$promote" 'helm push "$chart"'
has "$promote" 'gh release create "$RELEASE_TAG"'
has "$promote" '--generate-notes'
has "$promote" 'gh release download "$RELEASE_TAG"'
has "$promote" 'GitHub Release chart asset bytes mismatch'
! grep -Eq 'docker/build-push-action@|helm package |docker build |go build |:latest' "$promote" || fail 'promotion must not rebuild, package, or use latest'

has "$root/scripts/verify-signing-identity.sh" '.github/workflows/release-candidate.yml@refs/tags/$tag'
if find "$root" -type d \( -name .git -o -name .cache -o -name vendor \) -prune -o -type f \( -name Dockerfile -o -name 'Dockerfile.*' \) -exec awk 'toupper($1)=="FROM" {image=$2; if (image ~ /^--platform=/) image=$3; if (image !~ /@sha256:[0-9a-fA-F]{64}$/) exit 1}' {} +; then :; else fail 'Dockerfile FROM images must use sha256 digests'; fi
! grep -E -q '(:latest([^[:alnum:]_.-]|$)|image\.tag=latest)' "$workflows"/*.yml "$root/Makefile" "$root/deploy/helm-chart/kubernetes-secret-generator/values.yaml" || fail 'latest is forbidden in build, publish, and deployment inputs'
for path in "$workflows"/*.yml "$root/scripts/helm-release.sh"; do
	[ ! -f "$path" ] || ! grep -F -q -- '--force-conflicts' "$path" || fail '--force-conflicts is forbidden in release paths'
done

echo 'supply-chain static policy checks passed'
