{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": ["image", "profile", "scope", "migration", "crdLifecycle", "crdControllers", "leaderElection"],
  "properties": {
    "global": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "imageRegistry": { "type": "string" },
        "imagePullSecrets": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "image": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "tag", "digest", "pullPolicy"],
      "properties": {
        "registry": { "type": "string" },
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1, "not": { "pattern": "^(latest|LATEST)$" } },
        "digest": { "type": "string", "pattern": "^$|^sha256:[0-9a-f]{64}$" },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] },
        "pullSecrets": { "type": "array", "items": { "type": "string", "minLength": 1 } }
      }
    },
    "profile": { "enum": ["production", "dev"] },
    "replicaCount": { "type": ["integer", "null"], "minimum": 1 },
    "compatibilityProfile": { "enum": ["v4", "v3.4.1"] },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode", "namespaces"],
      "properties": {
        "mode": { "enum": ["ownNamespace", "namespaces", "cluster"] },
        "namespaces": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1,
            "maxLength": 63,
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "mode": { "const": "namespaces" } } },
          "then": { "properties": { "namespaces": { "minItems": 1 } } },
          "else": { "properties": { "namespaces": { "maxItems": 0 } } }
        }
      ]
    },
    "migration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmedScope", "confirmedNamespacesSHA256"],
      "properties": {
        "confirmedScope": { "enum": ["", "ownNamespace", "namespaces", "cluster"] },
        "confirmedNamespacesSHA256": { "type": "string", "pattern": "^$|^[0-9a-f]{64}$" }
      }
    },
    "crdLifecycle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["manager"],
      "properties": { "manager": { "enum": ["direct", "flux"] } }
    },
    "crdControllers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": { "enabled": { "type": "boolean" } }
    },
    "leaderElection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "id"],
      "properties": {
        "enabled": { "type": "boolean" },
        "id": { "type": "string", "minLength": 1, "maxLength": 63, "pattern": "^[a-z0-9]([-a-z0-9.]*[a-z0-9])?$" }
      }
    },
    "args": { "type": "array", "items": { "type": "string" } },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "priorityClassName": { "type": "string" },
    "terminationGracePeriodSeconds": { "type": "integer", "minimum": 1 },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "required": ["create", "name", "automountServiceAccountToken"],
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "resources": { "type": "object" },
    "nodeSelector": { "type": "object", "additionalProperties": { "type": "string" } },
    "tolerations": { "type": "array", "items": { "type": "object" } },
    "affinity": { "type": "object" },
    "topologySpreadConstraints": { "type": "array", "items": { "type": "object" } },
    "volumeMounts": { "type": "array", "items": { "type": "object" } },
    "volumes": { "type": "array", "items": { "type": "object" } },
    "regenerateInsecure": { "type": "boolean" },
    "secretLength": { "type": "integer", "minimum": 1, "maximum": 4096 },
    "sshKeyAlgorithm": { "enum": ["rsa", "ecdsa", "ed25519"] },
    "rbac": { "type": "object", "additionalProperties": false, "required": ["create"], "properties": { "create": { "type": "boolean" } } },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service", "serviceMonitor"],
      "properties": {
        "service": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "port", "annotations"],
          "properties": {
            "enabled": { "type": "boolean" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "annotations": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "interval", "scrapeTimeout", "labels"],
          "properties": {
            "enabled": { "type": "boolean" },
            "interval": { "type": "string", "pattern": "^[1-9][0-9]*(ms|s|m|h)$" },
            "scrapeTimeout": { "type": "string", "pattern": "^[1-9][0-9]*(ms|s|m|h)$" },
            "labels": { "type": "object", "additionalProperties": { "type": "string" } }
          }
        }
      }
    },
    "pdb": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "minAvailable"],
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": { "type": "integer", "minimum": 1 }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "ingress", "egress"],
      "properties": {
        "enabled": { "type": "boolean" },
        "ingress": { "type": "array", "items": { "type": "object" } },
        "egress": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "rules"],
          "properties": {
            "enabled": { "type": "boolean" },
            "rules": { "type": "array", "items": { "type": "object" } }
          }
        }
      }
    },
    "livenessProbe": { "$ref": "#/definitions/probe" },
    "readinessProbe": { "$ref": "#/definitions/probe" }
  },
  "allOf": [
    {
      "if": { "properties": { "profile": { "const": "production" } } },
      "then": {
        "properties": {
          "pdb": {
            "properties": {
              "enabled": { "const": true },
              "minAvailable": { "const": 1 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "replicaCount": { "type": "integer", "minimum": 2 } } },
      "then": {
        "properties": {
          "pdb": {
            "properties": {
              "enabled": { "const": true },
              "minAvailable": { "const": 1 }
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "probe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "initialDelaySeconds", "periodSeconds", "timeoutSeconds", "successThreshold", "failureThreshold"],
      "properties": {
        "enabled": { "type": "boolean" },
        "initialDelaySeconds": { "type": "integer", "minimum": 0 },
        "periodSeconds": { "type": "integer", "minimum": 1 },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "successThreshold": { "type": "integer", "minimum": 1 },
        "failureThreshold": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
